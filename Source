                local function refreshOptions()
                    DropArea:ClearAllChildren()
                    local L = Instance.new("UIListLayout")
                    L.SortOrder = Enum.SortOrder.LayoutOrder
                    L.Parent = DropArea
                    
                    local OptButtons = {} 
                    for _, opt in ipairs(options) do
                        local OBtn = Instance.new("TextButton")
