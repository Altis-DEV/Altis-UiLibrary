-- 1. Tạo Cửa Sổ (Window)
local Window = AltisLib.CreateWindow("Altis V3.9.1 - Ultimate Fix", UDim2.new(0, 550, 0, 400))

-- Thiết lập màu sắc và Background trong suốt
Window:SetMainColor(Color3.fromRGB(170, 85, 255)) -- Purple theme
Window:SetBackgroundTransparency(0.15) -- Ui mờ 15% (KHÔNG làm mờ Image)
Window:SetBackgroundImage("rbxassetid://13580456102") -- Ảnh nền tuỳ ý
Window:SetBackgroundImageTransparency(0.8)

-- Gửi Notification Chào mừng
Window:SendNotification("Thành công!", "AltisLib V3.9.1 đã được nạp hoàn chỉnh với TextWrapped Dynamic Resizing.", 5)

-- 2. Tạo Tab 1: General
local GeneralTab = Window:CreateTab("General Functions")

GeneralTab:CreateLabel("Đây là Label có Text siêu dài. Bạn hãy thử kéo góc Resize bên dưới lên để thu hẹp chiều ngang cửa sổ lại. Chữ sẽ bị ép xuống dòng và tự động giãn chiều cao của Label ra để không bị mất góc nào cả!")

GeneralTab:CreateParagraph("Thông tin phiên bản:", "- Khôi phục toàn bộ 900+ lines code gốc.\n- Fix Image Transparency riêng biệt.\n- Fix Auto-Size cho tất cả Frame khi text gập dòng.")

GeneralTab:CreateDivider()

GeneralTab:CreateButton("In ra Console", function()
    print("Button Clicked!")
    Window:SendNotification("Action", "Bạn vừa nhấn nút in ra Console", 3)
end)

GeneralTab:CreateToggle("Bật chế độ God Mode (Cái này cũng test Text Wrap siêu dài nếu bạn thích thử bóp hẹp cửa sổ vào nhé)", false, function(state)
    print("God Mode:", state)
end)

GeneralTab:CreateSlider("Chỉnh Tốc Độ Chạy (WalkSpeed) - Nếu kéo hẹp lại text cũng sẽ đẩy thanh slider xuống dưới", 16, 100, 16, function(value)
    if game.Players.LocalPlayer.Character and game.Players.LocalPlayer.Character:FindFirstChild("Humanoid") then
        game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = value
    end
end)

-- 3. Tạo Tab 2: Advanced
local AdvancedTab = Window:CreateTab("Advanced UI")

AdvancedTab:CreateImage("rbxassetid://10636284617") -- Test Ảnh (sẽ thấy ảnh rõ 100% trong khi UI vẫn mờ)

local MyDropdown = AdvancedTab:CreateDropdown("Lựa chọn Vũ Khí", {"Kiếm", "Súng", "Cung"}, "Kiếm", function(option)
    print("Đã chọn:", option)
end)

AdvancedTab:CreateButton("Cập nhật lại Dropdown", function()
    MyDropdown:Refresh({"Đao", "Pháo", "Giáo", "Khiên"})
    Window:SendNotification("Updated", "Đã refresh lại Dropdown", 3)
end)

AdvancedTab:CreateMultiDropdown("Chọn Skill kết hợp", {"Chém", "Phóng", "Chữa Lành", "Lướt"}, {"Chém", "Lướt"}, function(options)
    print("Các skill đang chọn:")
    for _, skill in ipairs(options) do print("-", skill) end
end)

AdvancedTab:CreateTextBox("Nhập tên người chơi muốn dịch chuyển tới", "Ví dụ: Player123", function(text, enterPressed)
    if enterPressed then
        print("Đang tìm người chơi:", text)
    end
end)

AdvancedTab:CreateKeybind("Phím ẩn/hiện Menu (Test Bind)", Enum.KeyCode.RightShift, function(key, pressed)
    if pressed then
        print("Đã bấm phím:", key.Name)
    end
end)

AdvancedTab:CreateColorPicker("Đổi màu UI Theme", Color3.fromRGB(170, 85, 255), function(color)
    Window:SetMainColor(color)
end)

-- 4. Tạo Tab 3: Nested Sections
local SectionTab = Window:CreateTab("Section & Sub-sections")

local MainSection = SectionTab:CreateSection("Khu vực cài đặt Chính")
MainSection:CreateToggle("Tự động cày cuốc", true, function(state) end)

local SubSection = MainSection:CreateSection("Cài đặt phụ của Cày Cuốc")
SubSection:CreateSlider("Khoảng cách quái", 10, 100, 50, function(value) end)
SubSection:CreateButton("Reset Config", function() end)

SectionTab:CreateSection("Khu vực Trống (Test Layout)")
