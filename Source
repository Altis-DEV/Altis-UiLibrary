                            else
                                OBtn.BackgroundColor3 = theme.ElementBg
                            end
                            OBtn.TextColor3 = theme.Text
                            OBtn.BackgroundTransparency = theme.ElementTransparency
                        end)
                        
                        OBtn.MouseButton1Click:Connect(function()
                            selected = opt
                            ToggleBtn.Text = " ► " .. text .. " [" .. tostring(opt) .. "]"
                            if WindowObj.Theme.Accent then 
                                for _, data in ipairs(OptButtons) do 
                                    if selected == data.Value then
                                        data.Btn.BackgroundColor3 = WindowObj.Theme.Accent 
                                    else
                                        data.Btn.BackgroundColor3 = WindowObj.Theme.ElementBg
                                    end
                                end 
                            end
                            callback(opt)
                            open = false
                            updateDropSize(true)
                        end)
