local IrisLib = loadstring(game:HttpGet("https://raw.githubusercontent.com/Altis-DEV/Altis-UiLibrary/refs/heads/main/Source"))()
-- Khởi tạo Cửa sổ giao diện chính
local Window = IrisLib.CreateWindow("AltisLib V3.7 - Showcase", UDim2.new(0, 550, 0, 380))

-- ==========================================
-- TAB 1: TÍNH NĂNG CHÍNH (MAIN FEATURES)
-- ==========================================
local MainTab = Window:CreateTab("Main Features")

-- 1. [MỚI] Thử nghiệm Paragraph
local WelcomePara = MainTab:CreateParagraph(
    "👋 Chào mừng đến với AltisLib!", 
    "Đây là tính năng Paragraph mới. Khung này sẽ tự động co giãn chiều cao theo độ dài của chữ. Rất thích hợp để làm Changelog, ghi chú, hoặc hướng dẫn sử dụng.\n\nCập nhật mới:\n- Thêm tính năng Smart Search Bar.\n- Thêm Paragraph tự co giãn.\n- Fix lỗi Dropdown."
)

MainTab:CreateDivider() -- Đường kẻ ngang

-- 2. Thử nghiệm Section & Các Element cơ bản
local CombatSection = MainTab:CreateSection("⚔️ Combat Settings")

CombatSection:CreateLabel("Đây là một Label bình thường")

CombatSection:CreateButton("Tấn công tự động (Click Me)", function()
    Window:SendNotification("Thông báo", "Đã bật chế độ tấn công tự động!", 3)
end)

CombatSection:CreateToggle("Bật Aimbot", false, function(state)
    print("Aimbot state:", state)
    if state then
        Window:SendNotification("Aimbot", "Đã khóa mục tiêu!", 2)
    end
end)

CombatSection:CreateSlider("Phạm vi hoạt động (FOV)", 0, 360, 90, function(value)
    print("FOV changed to:", value)
end)

-- 3. Thử nghiệm Section chứa Textbox và Dropdown
local MiscSection = MainTab:CreateSection("🛠️ Misc Settings")

MiscSection:CreateTextBox("Nhập tên người chơi", "Ví dụ: RobloxPlayer123", function(text, enterPressed)
    if enterPressed then
        Window:SendNotification("Tìm kiếm", "Đang tìm người chơi: " .. text, 3)
    end
end)

MiscSection:CreateDropdown("Chọn vũ khí", {"Kiếm", "Súng", "Cung tên", "Dao găm"}, "Kiếm", function(selected)
    print("Vũ khí được chọn:", selected)
end)

MiscSection:CreateMultiDropdown("Chọn Buff", {"Chạy nhanh", "Nhảy cao", "Tàng hình", "Bất tử"}, {"Chạy nhanh"}, function(selectedList)
    print("Các Buff đang bật:")
    for _, buff in ipairs(selectedList) do
        print("-", buff)
    end
end)


-- ==========================================
-- TAB 2: CÀI ĐẶT GIAO DIỆN (THEME & CONFIG)
-- ==========================================
local SettingsTab = Window:CreateTab("Settings")

-- Dùng Paragraph nhưng không có text để làm Tiêu đề lớn
SettingsTab:CreateParagraph("🎨 Tùy chỉnh giao diện", "")

-- 4. ColorPicker để đổi màu UI
SettingsTab:CreateColorPicker("Màu chủ đạo (Accent Color)", Color3.fromRGB(60, 100, 180), function(color)
    Window:SetMainColor(color)
end)

-- 5. Slider để chỉnh độ mờ (Transparency)
SettingsTab:CreateSlider("Độ trong suốt của UI", 0, 100, 0, function(value)
    -- Chuyển đổi từ 0-100 sang 0-1 (để phù hợp với Gui Transparency)
    Window:SetBackgroundTransparency(value / 100)
end)

SettingsTab:CreateDivider()

-- 6. Keybind ẩn hiện giao diện (Ví dụ)
SettingsTab:CreateKeybind("Phím tắt ẩn/hiện UI", Enum.KeyCode.RightShift, function(key, isTriggered)
    if isTriggered then
        -- Logic ẩn hiện UI bạn có thể thêm sau, ở đây ta in ra console
        print("Đã bấm phím tắt:", key.Name)
        Window:SendNotification("Keybind", "Bạn vừa bấm phím " .. key.Name, 2)
    end
end)

-- 7. Nút Update Paragraph Test
local UpdateBtn = SettingsTab:CreateButton("Cập nhật chữ của Paragraph bên Tab 1", function()
    WelcomePara:SetTitle("⚠️ THÔNG BÁO ĐÃ BỊ THAY ĐỔI")
    WelcomePara:SetText("Nội dung của Paragraph này đã được thay đổi bằng Script! Bạn có thể gọi SetTitle hoặc SetText bất cứ lúc nào.")
end)


-- ==========================================
-- TAB 3: CREDITS
-- ==========================================
local CreditTab = Window:CreateTab("Credits")

CreditTab:CreateParagraph("Nhà phát triển", "Giao diện được thiết kế và tinh chỉnh bởi bạn.\nCảm ơn vì đã sử dụng AltisLib!")
CreditTab:CreateButton("Copy Link Discord", function()
    -- Hàm copy (Yêu cầu executor hỗ trợ setclipboard)
    if setclipboard then
        setclipboard("https://discord.gg/your_link_here")
        Window:SendNotification("Thành công", "Đã copy link Discord vào khay nhớ tạm!", 3)
    else
        Window:SendNotification("Lỗi", "Executor của bạn không hỗ trợ copy!", 3)
    end
end)

-- Testing Dropdown
local Weapons = {"Sword", "Pistol", "Shotgun", "Sniper", "Rocket", "Knife"}
local WeaponDropdown = SelectionTab:CreateDropdown("Equip Weapon", Weapons, "Sword", function(selected)
    print("[AltisLib] Dropdown selected:", selected)
end)

-- Testing Dropdown Refresh Handler
SelectionTab:CreateButton("Refresh Weapon List", function()
    WeaponDropdown:Refresh({"Updated_Gun1", "Updated_Gun2", "Updated_Gun3"})
    Window:SendNotification("Refreshed", "Single Dropdown updated.", 2)
end)

SelectionTab:CreateDivider()

SelectionTab:CreateLabel("Multi-Dropdown Testing:")

-- Testing MultiDropdown
local ESPFeatures = {"Boxes", "Names", "Health", "Distance", "Tracers", "Skeleton"}
local ESPDropdown = SelectionTab:CreateMultiDropdown("ESP Settings", ESPFeatures, {"Boxes", "Names"}, function(selectedTable)
    print("[AltisLib] Current MultiDropdown selections:")
    for _, feature in ipairs(selectedTable) do
        print(" - " .. feature)
    end
end)

-- Testing MultiDropdown Refresh Handler
SelectionTab:CreateButton("Refresh ESP List", function()
    ESPDropdown:Refresh({"Enemies", "Teammates", "Loot", "Vehicles"})
    Window:SendNotification("Refreshed", "Multi Dropdown updated.", 2)
end)


-- ========================================================================
-- TAB 3: SECTIONS, COLORS & KEYBINDS
-- ========================================================================
local AdvancedTab = Window:CreateTab("Advanced")

-- Testing Section (Expandable/Collapsible)
local VisualSection = AdvancedTab:CreateSection("Visual Settings")

-- Testing ColorPicker (V3.5 Fixed Black Screen Bug)
VisualSection:CreateColorPicker("Accent Color", Color3.fromRGB(85, 170, 255), function(color)
    print("[AltisLib] ColorPicker changed to:", color)
    Window:SetMainColor(color) -- Dynamically updates the UI theme
end)

VisualSection:CreateColorPicker("ESP Box Color", Color3.fromRGB(255, 50, 50), function(color)
    print("[AltisLib] ESP Color changed.")
end)

local CombatSection = AdvancedTab:CreateSection("Combat Settings")

-- Testing Keybind
CombatSection:CreateKeybind("Aimbot Hotkey", Enum.KeyCode.E, function(key, isPressed)
    if isPressed then
        print("[AltisLib] Aimbot triggered by key:", key.Name)
    else
        print("[AltisLib] Aimbot keybind changed to:", key.Name)
    end
end)


-- ========================================================================
-- TAB 4: WINDOW UI SETTINGS & STRESS TEST
-- ========================================================================
local SettingsTab = Window:CreateTab("Settings")

SettingsTab:CreateLabel("Background Configuration:")

-- Testing UI background transparency
SettingsTab:CreateSlider("UI Transparency", 0, 100, 15, function(value)
    Window:SetBackgroundTransparency(value / 100)
end)

SettingsTab:CreateDivider()

-- Testing Image Background
SettingsTab:CreateTextBox("Image Asset ID", "rbxassetid://10459322831", function(text, enterPressed)
    if enterPressed then
        Window:SetBackgroundImage(text)
        Window:SendNotification("Background Updated", "Loaded image asset.", 3)
    end
end)

SettingsTab:CreateSlider("Image Transparency", 0, 100, 50, function(value)
    Window:SetBackgroundImageTransparency(value / 100)
end)

SettingsTab:CreateDivider()
SettingsTab:CreateLabel("Scrollbar Stress Test:")

-- Spawning 20 buttons to forcefully test the scrolling frame behavior
for i = 1, 20 do
    SettingsTab:CreateButton("Dummy Button " .. tostring(i), function()
        print("Clicked dummy button", i)
    end)
end
