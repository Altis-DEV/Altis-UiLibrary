                        SN.TextColor3 = theme.Text
                        SB.BackgroundColor3 = theme.WindowBg
                        SB.BorderColor3 = theme.Border
                        SB.BackgroundTransparency = theme.ElementTransparency
                        if name == "R" then 
                            SFill.BackgroundColor3 = Color3.fromRGB(255, 50, 50) 
                        elseif name == "G" then 
                            SFill.BackgroundColor3 = Color3.fromRGB(50, 255, 50) 
                        else 
                            SFill.BackgroundColor3 = Color3.fromRGB(50, 50, 255) 
                        end
                    end)

