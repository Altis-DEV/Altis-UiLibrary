                local function CreateRgbSlider(name, pos, min, max, initial, updateCb)
                    local SF = Instance.new("Frame")
                    SF.Size = UDim2.new(1, -20, 0, 20)
                    SF.Position = UDim2.new(0, 10, 0, pos)
                    SF.BackgroundTransparency = 1
