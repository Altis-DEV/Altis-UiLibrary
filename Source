            -- FIX IMAGE: Chia tách Fixed Size (ScaleType Stretch) và Không Size (ScaleType Fit + Size Responsive)
            function Elements:CreateImage(imageId, size)
                local ImgLabel = Instance.new("ImageLabel", container)
                ImgLabel.BorderSizePixel = 1
                ImgLabel.BorderColor3 = Color3.fromRGB(255, 255, 255)
                
                if size then
                    -- Khi người dùng nhập size cụ thể (cố định) -> Ép ảnh Stretch khít hoàn toàn vào viền.
                    ImgLabel.Size = size
                    ImgLabel.ScaleType = Enum.ScaleType.Stretch 
                else
                    -- Khi người dùng KHÔNG nhập size -> Lấy size mặc định, tự động cân bằng tỉ lệ ảnh bên trong.
                    ImgLabel.Size = UDim2.new(1, -8, 0, 150)
                    ImgLabel.ScaleType = Enum.ScaleType.Fit
                end
                
                local function parseImageId(id)
                    if type(id) == "number" then return "rbxassetid://" .. id end
                    if type(id) == "string" then
                        if id:find("rbxassetid://") or id:find("http") or id:find("rbxasset://") then return id end
                        local num = id:match("%d+")
                        if num then return "rbxassetid://" .. num end
                    end
                    return ""
                end
                
                ImgLabel.Image = parseImageId(imageId)
                
                RegisterTheme(function(theme)
                    ImgLabel.BackgroundColor3 = theme.ElementBg
                    ImgLabel.BackgroundTransparency = theme.ElementTransparency
                    ImgLabel.ImageTransparency = theme.ElementTransparency
                end)
                
                RegisterElement(ImgLabel, "image")
                
                local handler = {}
                function handler:SetImage(newId)
                    ImgLabel.Image = parseImageId(newId)
                end
                function handler:SetSize(newSize)
                    ImgLabel.Size = newSize
                    -- Khi đổi thành size cứng thì set lại Stretch để ép khít
                    ImgLabel.ScaleType = Enum.ScaleType.Stretch
                end
                return handler
            end

